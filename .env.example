APP_ENV=development
APP_NAME=SST Backend
SECRET_KEY=change-this-secret
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/sstdb
DISABLE_2FA=false
FRONTEND_URLS=http://localhost:3000,https://tu-frontend.onrender.com
LOCAL_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=15
OTP_EXPIRE_MINUTES=5
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@sst.local
