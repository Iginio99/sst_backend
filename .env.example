APP_ENV=development
APP_NAME=SST Backend
SECRET_KEY=change-this-secret
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/database?sslmode=require
DISABLE_2FA=false
FRONTEND_URLS=http://localhost:3000,https://tu-frontend.onrender.com
LOCAL_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=15
OTP_EXPIRE_MINUTES=5
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@sst.local
STORAGE_PROVIDER=
SUPABASE_PROJECT_ID=
SUPABASE_STORAGE_BUCKET=
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_DIRECT_HOST=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MAX_IMAGE_UPLOAD_MB=5
MAX_DOCUMENT_UPLOAD_MB=20
MAX_VIDEO_UPLOAD_MB=200
